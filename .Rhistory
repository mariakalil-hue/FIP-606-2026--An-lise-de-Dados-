library(tidyverse)
d22 <- read.csv("experiment_2022.csv")
d23 <- read.csv("experiment_2023.csv")
d24 <- read.csv("experiment_2024.csv")
glimpse(d22)
glimpse(d23)
glimpse(d24)
rbind(d22,d23)
glimpse(d22)
glimpse(d23)
glimpse(d24)
rbind(d22,d23)
d23a <- d23 |>
rename (yld = yield,
year = Year
)
d22a <- d22 |>
rename (site = location,
cult = cultivar,
rep = block,
trt = treatment,
sev = severity,
yld = yield_kg_ha)
glimpse(d22a)
d24a <- d24 |>
mutate(year = 2024) |>
rename (site = location,
cult = cultivar,
rep = block,
trt = treatment,
sev = severity_pct,
yld = yield_kg_ha) |>
select(year, 1:6)
# VERIFICANDO O RESULTADO:
glimpse(d24a)
d_all <- rbind(d22a,d23a,d24a)
glimpse (d_all)
d_alla <- d_all |>
mutate(trt = case_match(trt,
"ctrl" ~ "control",
"control " ~ "control",
"fung" ~ "Fungicide",
.default = trt #mantém os outros valores como estão, se já estiverem com o nome desejado
)) |>
mutate(site = case_match(site,
"Uberlandia" ~ "Uberlândia",
"Vicosa" ~ "Viçosa",
.default = site #mantém os outros valores como estão, se já estiverem com o nome desejado
))
glimpse(d_alla)
glimpse(d_alla)
